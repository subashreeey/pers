if __name__ == "__main__":
    # Read DDL from stdin or file
    if len(sys.argv) > 1:
        with open(sys.argv[1], 'r') as f:
            ddl_text = f.read()
    else:
        ddl_text = sys.stdin.read()
   
    ddl_statements = ddl_text.strip().split('\n')
    erd_dot = generate_erd(ddl_statements)
    print(erd_dot)
   
    # Optional: Render to PNG
    from graphviz import Source
    src = Source(erd_dot)
    src.render('erd_output', format='png', cleanup=True)
    print("ERD rendered to erd_output.png")
 
